// ═══  FACIAL ALERT CONFIG PANEL  ══════════════════════════════
function FacialAlertConfigPanel() {
  const [config, setConfig] = useState<any>(null)
  const [loading, setLoading] = useState(true)
  const [saving, setSaving] = useState(false)
  const [testing, setTesting] = useState(false)
  const [msg, setMsg] = useState<{ type: 'success' | 'error'; text: string } | null>(null)
  const token = localStorage.getItem('iot_token') || ''
  const headers = { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' }

  useEffect(() => {
    fetch('/api/ip-cameras/facial-alert-config', { headers })
      .then(r => r.json())
      .then(d => { setConfig(d); setLoading(false) })
      .catch(() => setLoading(false))
  }, [])

  async function save() {
    setSaving(true)
    setMsg(null)
    try {
      const r = await fetch('/api/ip-cameras/facial-alert-config', {
        method: 'PUT', headers, body: JSON.stringify(config)
      })
      const d = await r.json()
      if (d.ok) setMsg({ type: 'success', text: 'Configurações salvas com sucesso!' })
      else setMsg({ type: 'error', text: d.error || 'Erro ao salvar' })
    } catch (e: any) {
      setMsg({ type: 'error', text: e.message })
    } finally { setSaving(false) }
  }

  async function testTelegram() {
    setTesting(true)
    setMsg(null)
    try {
      const r = await fetch('/api/ip-cameras/facial-alert-config/test-telegram', {
        method: 'POST', headers
      })
      const d = await r.json()
      if (d.ok) setMsg({ type: 'success', text: `✅ Mensagem de teste enviada! ID: ${d.message_id}` })
      else setMsg({ type: 'error', text: d.error || 'Erro ao enviar teste' })
    } catch (e: any) {
      setMsg({ type: 'error', text: e.message })
    } finally { setTesting(false) }
  }

